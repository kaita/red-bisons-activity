# Public Google OAuth client ID for Google Identity Services.
GOOGLE_CLIENT_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com"

# Google service account credentials. Store these as Cloudflare Worker secrets.
GOOGLE_SERVICE_ACCOUNT_EMAIL="red-bisons-worker@YOUR_PROJECT.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Google resources.
SHEET_ID="YOUR_GOOGLE_SHEET_ID"
CALENDAR_ID="YOUR_SHARED_GOOGLE_CALENDAR_ID"

# Comma-separated admin Google accounts.
ADMIN_EMAILS="admin@example.com"

# Optional, comma-separated allowed browser origins for local development.
ALLOWED_ORIGINS="http://localhost:8787"

# Optional for Raspberry Pi / Node.js runtime.
HOST="127.0.0.1"
PORT="8787"

# Local-only demo mode. Do not enable this in production.
DEMO_MODE="false"
